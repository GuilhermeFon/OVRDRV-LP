# OVRDRV — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.

# Endpoint do Google Apps Script (Web App, termina em /exec) que recebe os
# leads da Lista VIP e grava na planilha do Google Sheets.
# Publicar em: Apps Script → Implantar → Nova implantação → App da Web
# ("Executar como: eu" · "Quem pode acessar: Qualquer pessoa").
NEXT_PUBLIC_SHEET_ENDPOINT=

# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX).
# Pegue em: GA4 → Admin → Fluxos de dados → seu stream. Vazio = analytics off.
NEXT_PUBLIC_GA_ID=

# URL canônica do site (sem barra no final). Usada em SEO/OG/robots/sitemap.
# Ex: https://ovrdrv.com  (em preview do Netlify, a URL do deploy).
NEXT_PUBLIC_SITE_URL=
